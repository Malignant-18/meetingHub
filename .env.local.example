# ============================================================
# .env.local — NEVER commit this file. It is in .gitignore.
# ============================================================

# --- CLERK (Authentication) ---
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Clerk redirect URLs (keep these as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- SUPABASE (Database + Storage) ---
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME

# --- PRISMA + SUPABASE POSTGRES ---
# Get from: Supabase → Settings → Database → Connection String
# Use "Transaction" mode URL for DATABASE_URL (port 6543)
# Use "Session" mode URL for DIRECT_URL (port 5432)
DATABASE_URL=postgresql://postgres.REPLACE_ME:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.REPLACE_ME:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# --- SUPABASE STORAGE ---
# Same as above — used for server-side uploads
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# --- GOOGLE GEMINI ---
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=REPLACE_ME

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
